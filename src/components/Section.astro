---
interface Props {
  id: string;
  title: string;
  kicker?: string;
}
const { id, title, kicker } = Astro.props;
---

<section id={id} class="scroll-mt-20 py-16 sm:py-20">
  <div class="reveal">
    {kicker && <p class="mb-2 font-mono text-sm text-accent-600 dark:text-accent-400">{kicker}</p>}
    <h2 class="mb-8 text-3xl font-bold tracking-tight text-slate-900 sm:text-4xl dark:text-white">
      {title}
    </h2>
  </div>
  <slot />
</section>
