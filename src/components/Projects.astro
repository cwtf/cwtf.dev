---
import { PROJECTS } from '../data/site';
import BrandIcon from './BrandIcon.astro';
import Section from './Section.astro';
---

<Section id="projects" title="Projects" kicker="// what I've shipped">
  <p class="reveal -mt-4 mb-8 max-w-2xl text-slate-600 dark:text-slate-400">
    All four are live and used directly in training delivery. Participants get working,
    real-world reference points, not slideware.
  </p>

  <div class="grid gap-6 sm:grid-cols-2">
    {
      PROJECTS.map((p) => (
        <article class="reveal brand-hover group flex flex-col rounded-2xl border border-slate-200 bg-slate-50 p-6 transition-all duration-300 hover:-translate-y-1 hover:border-accent-400 hover:shadow-lg hover:shadow-accent-500/10 dark:border-slate-800 dark:bg-slate-900 dark:hover:border-accent-500">
          <div class="mb-3 flex items-start justify-between gap-3">
            <div class="flex items-center gap-3">
              <BrandIcon
                slug={p.icon}
                monogram={p.monogram}
                img={p.img}
                emoji={p.emoji}
                brand={p.brand}
                class={p.preserveLogoDetail ? 'brand-detailed' : ''}
                size="size-8"
              />
              <div>
                <h3 class="text-lg font-bold text-slate-900 dark:text-white">{p.name}</h3>
                <p class="text-sm text-slate-500 dark:text-slate-400">{p.tagline}</p>
              </div>
            </div>
          </div>

          <ul class="mb-4 flex-1 space-y-2 text-sm leading-relaxed">
            {p.points.map((pt) => (
              <li class="flex gap-2">
                <span class="mt-0.5 select-none text-accent-500" aria-hidden="true">
                  ▸
                </span>
                <span>{pt}</span>
              </li>
            ))}
          </ul>

          <div class="mb-4 flex flex-wrap gap-2">
            {p.tech.map((t) => (
              <span class="brand-hover inline-flex items-center gap-1.5 rounded-full border border-slate-200 bg-white px-2.5 py-1 font-mono text-xs text-slate-600 dark:border-slate-700 dark:bg-slate-800 dark:text-slate-300">
                {t.icon && <BrandIcon slug={t.icon} size="size-3.5" />}
                {t.label}
              </span>
            ))}
          </div>

          <a
            href={p.url}
            target="_blank"
            rel="noopener noreferrer"
            class="inline-flex items-center gap-1.5 font-mono text-sm font-semibold text-accent-600 transition-colors hover:text-accent-500 dark:text-accent-400 dark:hover:text-accent-300"
          >
            {p.urlLabel}
            <svg class="size-3.5 transition-transform group-hover:translate-x-0.5 group-hover:-translate-y-0.5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
              <path d="M7 17 17 7M7 7h10v10" />
            </svg>
          </a>
        </article>
      ))
    }
  </div>
</Section>
